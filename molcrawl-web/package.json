{
  "name": "molcrawl-web",
  "version": "1.0.0",
  "description": "MolCrawl Dataset Browser - Web interface for exploring fundamental models dataset",
  "main": "server.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "check-env": "node check-config.js",
    "preserver": "node check-config.js",
    "server": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "prod": "npm run build && npm run server",
    "lint": "npx eslint src --ext .js,.jsx",
    "lint:fix": "npx eslint src --ext .js,.jsx --fix",
    "format": "npx prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "npx prettier --check \"src/**/*.{js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "node-fetch": "^2.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:3001",
  "keywords": [
    "molcrawl",
    "dataset",
    "browser",
    "fundamental-models",
    "machine-learning",
    "bioinformatics"
  ],
  "author": "RIKEN",
  "license": "MIT"
}
